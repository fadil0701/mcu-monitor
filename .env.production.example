APP_NAME="Monitoring MCU PPKP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://puspelkes.jakarta.go.id/mcuppkp
ASSET_URL=https://puspelkes.jakarta.go.id/mcuppkp
APP_USE_REQUEST_URL=false

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

APP_PORT=9003

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=monitoring_mcu
DB_USERNAME=monitoring
DB_PASSWORD=GANTI_PASSWORD_DB_KUAT
MYSQL_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/mcuppkp/
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="mcu@puspelkes.jakarta.go.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

TRUSTED_PROXIES=*

# Kosongkan jika VM tidak wajib proxy. Contoh VM Puspelkes:
# HTTP_PROXY=http://10.15.3.20:80
# HTTPS_PROXY=http://10.15.3.20:80
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,mysql,.local,10.0.0.0/8

SUPER_ADMIN_NAME="Super Admin MCU"
SUPER_ADMIN_EMAIL=admin@ppkp.jakarta.go.id
SUPER_ADMIN_PASSWORD=GantiPasswordKuat123!

MCU_INTERVAL_YEARS=3
MCU_DEFAULT_LOCATION="Klinik Utama Balaikota"
MCU_DAILY_QUOTA=100
MCU_MENU_MASTER_DATA_ENABLED=false
MCU_MAX_FILE_SIZE=10240
MCU_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=
WHATSAPP_PHONE_NUMBER=

# Bridge CKG (isi setelah API bridge tersedia di dashboard-skrining)
CKG_API_BASE_URL=http://127.0.0.1:9006
CKG_API_KEY=
CKG_API_KEY_HEADER=X-Mcu-Api-Key
CKG_SYNC_PER_PAGE=100
