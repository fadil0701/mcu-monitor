APP_NAME="Monitoring MCU"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:9003
ASSET_URL=http://127.0.0.1:9003

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
APP_USE_REQUEST_URL=false

BCRYPT_ROUNDS=12
LOG_CHANNEL=stderr
LOG_LEVEL=info

APP_PORT=9003
FORWARD_DB_PORT=3307

# PostgreSQL — mcu-monitor (alias: mcu-monitor-postgres)
# PGSQL_PASSWORD = MCU_DB_PASSWORD di ../health-platform/.env
DB_CONNECTION=pgsql
PGSQL_HOST=mcu-monitor-postgres
PGSQL_PORT=5432
PGSQL_DATABASE=mcu_monitor
PGSQL_USERNAME=mcu_monitor
PGSQL_PASSWORD=Ppkp-Dev-2026!
PGSQL_SSLMODE=prefer

# ── MySQL legacy (sumber migrasi) — profile: docker compose --profile mysql-legacy up -d mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=monitoring_mcu
MYSQL_USERNAME=monitoring
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_FROM_ADDRESS="mcu@example.com"
MAIL_FROM_NAME="${APP_NAME}"
VITE_APP_NAME="${APP_NAME}"

SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=GantiPasswordKuat123!

MCU_INTERVAL_YEARS=3
MCU_DEFAULT_LOCATION="Klinik Utama Balaikota"
MCU_DAILY_QUOTA=100
MCU_MENU_MASTER_DATA_ENABLED=false
MCU_MAX_FILE_SIZE=10240
MCU_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_API_BASE_URL=https://chat.api.co.id

BACKUP_DIR=storage/backups/database
BACKUP_RETENTION_DAYS=14
BACKUP_COMPRESS=true
BACKUP_ENCRYPT=false

TRUSTED_PROXIES=*

# Bridge dashboard-skrining (HTTP — tetap setelah migrasi PG)
CKG_API_BASE_URL=http://host.docker.internal:9006
CKG_API_KEY=
CKG_API_KEY_HEADER=X-Mcu-Api-Key
CKG_SYNC_PER_PAGE=100
CKG_BRIDGE_DISABLE_PROXY=true
CKG_BRIDGE_INTERNAL_HOST=host.docker.internal
CKG_BRIDGE_INTERNAL_PORT=9006

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,mysql,mcu-monitor-postgres,ppkp-postgres,.local
