APP_NAME="Monitoring MCU"
APP_ENV=production
# Generate dulu: php artisan key:generate --show
APP_KEY=base64:ISI_DENGAN_OUTPUT_KEY_GENERATE
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Docker Compose: DB_HOST otomatis di-override ke "mysql"
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=monitoring_mcu
DB_USERNAME=monitoring
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="mcu@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Port publikasi aplikasi (docker-compose)
APP_PORT=8080
FORWARD_DB_PORT=3307

# Super Admin — isi lalu jalankan setelah container up:
# docker compose exec app php artisan user:create-admin --from-env
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=GantiPasswordKuat123!

# MCU Configuration
MCU_INTERVAL_YEARS=3
MCU_DEFAULT_LOCATION="Klinik Utama Balaikota"
MCU_DAILY_QUOTA=100
MCU_MENU_MASTER_DATA_ENABLED=false
MCU_MAX_FILE_SIZE=10240
MCU_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# WhatsApp (optional)
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=
WHATSAPP_PHONE_NUMBER=

# Reverse proxy (nginx/traefik di depan container)
TRUSTED_PROXIES=*
