APP_NAME="Monitoring MCU"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Docker + PostgreSQL (health-platform): salin .env.docker.example → .env
# Produksi VM: salin .env.production.example → .env
# Mapping password: health-platform/docs/deployment/APP-ENV.md
#   PGSQL_PASSWORD = MCU_DB_PASSWORD di health-platform/.env

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
PGSQL_HOST=mcu-monitor-postgres
PGSQL_PORT=5432
PGSQL_DATABASE=mcu_monitor
PGSQL_USERNAME=mcu_monitor
PGSQL_PASSWORD=Ppkp-Dev-2026!
PGSQL_SSLMODE=prefer

# MySQL legacy (migrasi satu kali): docker compose --profile mysql-legacy up -d mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=monitoring_mcu
# DB_USERNAME=monitoring
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="mcu@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Super Admin — isi lalu jalankan: php artisan user:create-admin --from-env
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=

# MCU Configuration
MCU_INTERVAL_YEARS=3
MCU_DEFAULT_LOCATION="Klinik Utama Balaikota"
MCU_DAILY_QUOTA=100
MCU_MENU_MASTER_DATA_ENABLED=false
MCU_MAX_FILE_SIZE=10240
MCU_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# WhatsApp (optional)
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE_ID=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_API_BASE_URL=https://chat.api.co.id

# Database backup (Super Admin → Backup Database)
BACKUP_DIR=storage/backups/database
BACKUP_RETENTION_DAYS=14
BACKUP_COMPRESS=true
BACKUP_ENCRYPT=false
# BACKUP_GPG_PASSPHRASE_FILE=.backup-passphrase
# Laragon Windows (opsional — D:/laragon dideteksi otomatis)
# LARAGON_ROOT=D:/laragon
# BACKUP_MYSQL_BIN_DIR=D:/laragon/bin/mysql/mysql-8.0.30-winx64/bin
# MYSQL_ROOT_PASSWORD=  # wajib di Docker agar mysqldump dari container app berhasil
